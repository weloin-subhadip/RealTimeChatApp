# Compose configuration. Copy to .env before running Docker:
#   cp .env.example .env
# docker-compose.yml reads these for the server service.

# JWT secrets — replace with long random strings for any real deployment.
JWT_ACCESS_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Host port for the app (nginx). Open http://localhost:${CLIENT_PORT}
CLIENT_PORT=8080
